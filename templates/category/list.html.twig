{% extends 'base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block body %}
<h1>Catégories</h1>

{% if categories %}
    <ul>
        {% for category in categories %}
            <li>
                <a href="{{ path('app_category_show', {id: category.id}) }}">{{ category.name }}</a>
            </li>
        {% endfor %}
    </ul>
{% else %}
    <p>Aucune catégorie disponible.</p>
{% endif %}
{% endblock %}
